#: core/serializers/payments.py:87
msgid "Installment is already marked as paid"
msgstr "القسط مسدد بالفعل."

#: core/serializers/payments.py:89
msgid "Cannot mark installment as unpaid once it has been paid"
msgstr "لا يمكن اعتبار القسط غير مسدد و هو مدفوع بالفعل"

#: core/serializers/units.py:54 core/serializers/units.py:267
msgid "This field is required to make a payment plan."
msgstr "هذه الخانة مطلوبة لإنشاء خطة دفع."

#: core/serializers/units.py:57 core/serializers/units.py:270
msgid "Starting month must be 1 or higher."
msgstr "يجب أن يكون شهر البداية 1 أو أكثر."

#: core/serializers/units.py:131 core/serializers/units.py:405
msgid "If creating a new client, all new client fields must be filled."
msgstr "إذا كنت تقوم بإنشاء عميل جديد، يجب تعبئة جميع خانات العميل الجديد."

#: core/serializers/units.py:142 core/serializers/units.py:144
#: core/serializers/units.py:446 core/serializers/units.py:448
msgid "This field is required when unit status is set to 'On Hold'"
msgstr "هذه الخانة مطلوبة عندما تكون حالة الوحدة 'معلق'"

#: core/serializers/units.py:147 core/serializers/units.py:451
msgid "Hold deposit cannot be set if unit status is not 'On Hold'"
msgstr "لا يمكن تعيين وديعة الحجز إذا لم تكن حالة الوحدة 'معلق'"

#: core/serializers/units.py:149 core/serializers/units.py:453
msgid "Hold expiry date cannot be set if unit status is not 'On Hold'"
msgstr "لا يمكن تعيين تاريخ انتهاء الحجز إذا لم تكن حالة الوحدة 'معلق'"

#: core/serializers/units.py:165
msgid "Unit status cannot be available while associated with a client."
msgstr "لا يمكن أن تكون الوحدة متاحة وهي مرتبطة بعميل."

#: core/serializers/units.py:415
msgid "Cannot edit an installment that's already paid"
msgstr "لا يمكن تعديل قسط تم دفعه بالفعل"

#: core/validators.py:30
msgid ""
"Enter a valid phone number. Only digits, spaces, hyphens, parentheses, and "
"an optional leading '+' are allowed."
msgstr ""
"أدخل رقم هاتف صالح. يسمح فقط بالأرقام، المسافات، الشرطات، الأقواس، ورمز '+' "
"كرمز اختياري في البداية."

#: users/serializers.py:44
msgid "Both password fields are required."
msgstr "كلا خانات كلمة المرور مطلوبان."

#: users/serializers.py:46
msgid "Passwords do not match."
msgstr "كلمتا المرور غير متطابقتين."

#: users/validators.py:10
msgid "Password must contain at least one digit."
msgstr "يجب أن تحتوي كلمة المرور على رقم واحد على الأقل."

#: users/validators.py:14
msgid "Your password must contain at least one digit [0-9]."
msgstr "يجب أن تحتوي كلمة المرور الخاصة بك على رقم واحد على الأقل [0-9]."
